{
  "name": "dms-workspace",
  "private": true,
  "packageManager": "npm@11.17.0",
  "workspaces": [
    "apps/dms-console/frontend",
    "packages/*"
  ],
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    }
  },
  "scripts": {
    "dev": "npm run dev:dms:frontend",
    "dev:dms:frontend": "npm --workspace @dms/console-frontend run dev",
    "build:dms:frontend": "npm --workspace @dms/console-frontend run build",
    "lint:dms:frontend": "npm --workspace @dms/console-frontend run lint",
    "typecheck:dms:frontend": "npm --workspace @dms/console-frontend run typecheck"
  }
}
