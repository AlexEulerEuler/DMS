DMS_ENVIRONMENT=local
DMS_PROJECT_NAME=DMS Console Backend
DMS_VERSION=0.1.0

# GitHub proxy (optional). When all three are set, Issues are proxied to the real
# GitHub REST API; otherwise an in-memory mock is used so the console still works
# end-to-end without external setup.
DMS_GITHUB_TOKEN=
DMS_GITHUB_OWNER=
DMS_GITHUB_REPO=

# Persistence + storage (docs/ia/runtime.md §1-2). Defaults are fine for local dev.
DMS_DB_PATH=./dms.db
DMS_STORAGE_DIR=./storage
# Seed sample data into an empty DB (1 dev / 0 clean prod start).
DMS_SEED=1
# Docs root the agent loop reads (defaults to apps/dms-console/docs).
# DMS_DOCS_DIR=

# Optional shared-secret API gate (runtime.md §5). When set, /api/* (except
# /api/health) requires `Authorization: Bearer <token>`. Leave empty = open.
DMS_API_TOKEN=
